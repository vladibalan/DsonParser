# ---- clangd index cache (generated; compile_commands.json itself is tracked) ----
# clangd writes its background index under .cache/clangd/. The .clangd config
# file (no trailing slash) and compile_commands.json are tracked, not ignored.
.cache/

# ---- OS noise ----
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
DsonTest2/TestFiles/

# ---- Agent handoff scratch (Director <-> Implementer task/feedback files) ----
# Per-task task-<id>.md / feedback-<id>.md live here during a run and move to
# .handoff/history/ when the task closes. Local-only workflow scratch: never
# tracked, kept out of the git diff the Director verifies against, and out of
# agent discovery (see CLAUDE.md "Do NOT read" and docs/agent-workflow.md).
.handoff/

# ---- Memory-store maintenance (shared Claude memory prune manifest + routing) ----
# Local-only working docs for pruning the shared Claude memory store; not part of
# the library. See memory-maintenance/memory-prune-manifest.md.
memory-maintenance/
