# clangd configuration for DsonParser.
#
# Jump-to-definition / cross-references are driven by compile_commands.json at
# the repo root (generated by tools/gen-compile-commands.ps1). Regenerate that
# file after adding/removing .cpp files or changing include dirs/defines.
#
# Two YAML fragments below, separated by `---`: a global fragment, then a
# conditional one that excludes the vendored RapidJSON tree from indexing.

CompileFlags:
  # The compile database uses the clang-cl driver with MSVC-style flags.
  Compiler: clang-cl
Index:
  Background: Build

---
# Do not index the vendored RapidJSON tree (~35 headers). It is third-party and
# never the answer to a task here; indexing it only adds noise and slows clangd.
If:
  PathMatch: .*/DsonParser/include/rapidjson/.*
Index:
  Background: Skip
